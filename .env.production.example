NODE_ENV=production
POSTGRES_DB=market_dominion
POSTGRES_USER=market
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://market:replace-with-a-long-random-password@postgres:5432/market_dominion
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
DOMAIN=market.wondering.kr
CORS_ORIGINS=https://market.wondering.kr
MATCHING_CONCURRENCY=1
MAX_LIVE_STRATEGIES_PER_USER=5
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=market_admin
ADMIN_NICKNAME=관리자
ADMIN_PASSWORD=replace-with-a-unique-16-plus-character-password
