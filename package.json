    "db:init": "node server/scripts/initDb.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "3.0.2",
    "better-sqlite3": "12.11.1",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "9.2.3",
    "daisyui": "5.6.13",
    "nodemon": "3.1.11",
    "tailwindcss": "4.3.2",
    "vite": "7.3.6"
  },
  "engines": {
    "node": ">=22.12"
  }
